# Django Secret Key
# 🔑 How to generate: run this command on your EC2 server (inside venv):
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Copy the output and paste it below (keep it secret, never share it!)
SECRET_KEY=your-secret-key-here

# Allowed hosts (your EC2 IP + both domain versions)
ALLOWED_HOSTS=65.0.203.55,kamaliakhaddark.com,www.kamaliakhaddark.com

# Database — SQLite is default (free, simple, works on EC2)
USE_SQLITE=true

# PostgreSQL (only needed if USE_SQLITE=false — ignore for now)
DB_NAME=kamalia_store
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# CSRF trusted origins — must match what users type in browser
CSRF_TRUSTED_ORIGINS=http://65.0.203.55,http://kamaliakhaddark.com,http://www.kamaliakhaddark.com

# SSL Redirect — set to true ONLY after you install SSL/HTTPS certificate
SECURE_SSL_REDIRECT=false
